NODE_ENV=development
PORT=5000

# ── Supabase Database ────────────────────────────────────────────────────────
# Supabase Dashboard → Project Settings → Database → Connection string → URI
# Use the "Transaction pooler" string (port 6543) for serverless/node backends
SUPABASE_DB_URL=postgresql://postgres.vroikfskstngmsrmxgau:HirenixCompany%402026@aws-1-ap-south-1.pooler.supabase.com:6543/postgres

# ── JWT (unchanged) ───────────────────────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRE=7d

# ── App (unchanged) ───────────────────────────────────────────────────────────
CLIENT_URL=http://localhost:5173
RESET_PASSWORD_URL=http://localhost:5173
MAX_FILE_SIZE=5242880

# Required for student-only email verification.
# Do not enable global Supabase email confirmation for this app; companies must remain unaffected.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=SUPABASE_SERVICE_ROLE_KEY

# Email for password reset and enquiries
# For Gmail, use an App Password, not your normal account password.
EMAIL_SERVICE=gmail
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM="Hiresnix <no-reply@hiresnix.co.in>"
ADMIN_EMAIL=

# Or use generic SMTP instead of EMAIL_SERVICE
